<UserControl x:Class="UsageTrackerNative.Modules.SubjectManagement.SubjectManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ManageCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrushAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="CategoryItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.12*" />
            <RowDefinition Height="0.88*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Subjects.Title}" FontSize="34" FontWeight="Black" />
            </StackPanel>
            <Border Grid.Column="1" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="16,10" VerticalAlignment="Top">
                <TextBlock x:Name="CurrentPathText" FontWeight="Black" />
            </Border>
            <TextBlock x:Name="SubjectStatusText"
                       Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Text="{DynamicResource App.Ready}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,10,0,0"
                       FontWeight="SemiBold" />
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource ManageCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Subjects.Major}" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MajorPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2">
                        <TextBox x:Name="MajorInput" Height="36" Margin="0,0,0,8" VerticalContentAlignment="Center" KeyDown="MajorInput_KeyDown" />
                        <Button Content="{DynamicResource Subjects.AddMajor}" Height="40" Click="AddMajorButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource ManageCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Subjects.Parent}" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ParentPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2">
                        <TextBox x:Name="ParentInput" Height="36" Margin="0,0,0,8" VerticalContentAlignment="Center" KeyDown="ParentInput_KeyDown" />
                        <Button Content="{DynamicResource Subjects.AddParent}" Height="40" Click="AddParentButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource ManageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Subjects.Child}" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChildPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2">
                        <TextBox x:Name="ChildInput" Height="36" Margin="0,0,0,8" VerticalContentAlignment="Center" KeyDown="ChildInput_KeyDown" />
                        <Button Content="{DynamicResource Subjects.AddChild}" Height="40" Click="AddChildButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.82*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.92*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource ManageCardStyle}" PreviewKeyDown="DetailsPanel_PreviewKeyDown">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Subjects.Detail}" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Border Style="{StaticResource CategoryItemStyle}"><TextBlock x:Name="SelectedNameText" VerticalAlignment="Center" FontWeight="Black" /></Border>
                    <Border Style="{StaticResource CategoryItemStyle}"><TextBlock x:Name="SelectedLevelText" VerticalAlignment="Center" FontWeight="Black" /></Border>
                    <Grid x:Name="DeleteActionHost" Margin="0,8,0,0" Height="40" MouseLeave="DeleteActionHost_MouseLeave" Background="Transparent">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="{DynamicResource Subjects.Rename}" MinWidth="92" Height="40" Click="RenameButton_Click" />
                            <Button x:Name="DeleteSubjectButton"
                                    Content="{DynamicResource Subjects.Delete}"
                                    MinWidth="92"
                                    Height="40"
                                    Margin="10,0,0,0"
                                    Click="DeleteSubjectButton_Click"
                                    MouseRightButtonDown="DeleteSubjectButton_MouseRightButtonDown" />
                        </StackPanel>
                        <Border x:Name="DeleteBehaviorFlyout"
                                Width="158"
                                Height="40"
                                Margin="196,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Opacity="0"
                                Visibility="Collapsed"
                                RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DeleteBehaviorFlyoutTransform" X="-18" />
                            </Border.RenderTransform>
                            <Button x:Name="DeleteBehaviorButton"
                                    Height="38"
                                    MinWidth="156"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Click="DeleteBehaviorButton_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="PromoteDeleteModeText" Text="{DynamicResource Subjects.Promote}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="DeleteModeSeparatorText" Text=" / " FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock x:Name="MatchRulesDeleteModeText" Text="{DynamicResource Subjects.MatchRules}" FontSize="14" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource ManageCardStyle}" PreviewKeyDown="KeywordPanel_PreviewKeyDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Subjects.Keywords}" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="KeywordPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBox x:Name="KeywordInput" Height="36" Margin="0,0,0,8" VerticalContentAlignment="Center" KeyDown="KeywordInput_KeyDown" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Subjects.AddKeyword}" MinWidth="112" Height="40" Click="AddKeywordButton_Click" />
                            <Button Content="{DynamicResource Subjects.DeleteSelected}" MinWidth="112" Height="40" Margin="10,0,0,0" Click="DeleteLastKeywordButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource ManageCardStyle}" PreviewKeyDown="ParallelWhitelistPanel_PreviewKeyDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Subjects.ParallelWhitelist}" FontSize="18" FontWeight="Black" />
                        <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="999" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock x:Name="ParallelWhitelistCountText" Text="{DynamicResource Subjects.CountFormat}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" />
                        </Border>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ParallelWhitelistPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBox x:Name="ParallelWhitelistInput" Height="36" Margin="0,0,0,8" VerticalContentAlignment="Center" KeyDown="ParallelWhitelistInput_KeyDown" ToolTip="{DynamicResource Subjects.ParallelInputHint}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Subjects.AddProcess}" MinWidth="112" Height="40" Click="AddParallelWhitelistButton_Click" />
                            <Button Content="{DynamicResource Subjects.DeleteSelected}" MinWidth="112" Height="40" Margin="10,0,0,0" Click="DeleteSelectedParallelWhitelistButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
