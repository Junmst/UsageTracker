<Window x:Class="UsageTrackerNative.Modules.SubjectManagement.RenameSubjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource PanelBrushAlt}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="22"
            Padding="0"
            MinWidth="380">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="18,16,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="重命名分类"
                           FontSize="18"
                           FontWeight="Black"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="×"
                        Width="32"
                        Height="32"
                        Padding="0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Click="CancelButton_Click" />
            </Grid>

            <Grid Grid.Row="1" Margin="18,0,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox x:Name="NameInput"
                         Grid.Row="0"
                         Height="40"
                         MinWidth="344"
                         VerticalContentAlignment="Center"
                         Padding="12,0"
                         KeyDown="NameInput_KeyDown" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button x:Name="CancelButton"
                            Content="取消"
                            MinWidth="88"
                            Height="38"
                            Click="CancelButton_Click" />
                    <Button x:Name="ConfirmButton"
                            Content="确定"
                            MinWidth="88"
                            Height="38"
                            Margin="10,0,0,0"
                            Background="{DynamicResource AccentRedBrush}"
                            BorderBrush="{DynamicResource AccentRedBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
