<UserControl x:Class="UsageTrackerNative.Modules.Overview.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="OverviewCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrushAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{DynamicResource Overview.TodayDashboard}" FontSize="34" FontWeight="Black" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{DynamicResource PanelBrushAlt}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="18">
                <StackPanel Width="460">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBox x:Name="YearInput" Width="92" Height="40" Text="2026" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Black" FontSize="17" PreviewMouseWheel="DateInput_PreviewMouseWheel" KeyDown="DateInput_KeyDown" />
                        <TextBlock Text="{DynamicResource Overview.Year}" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="16" />
                        <TextBox x:Name="MonthInput" Width="64" Height="40" Text="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Black" FontSize="17" PreviewMouseWheel="DateInput_PreviewMouseWheel" KeyDown="DateInput_KeyDown" />
                        <TextBlock Text="{DynamicResource Overview.Month}" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="16" />
                        <TextBox x:Name="DayInput" Width="64" Height="40" Text="27" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Black" FontSize="17" PreviewMouseWheel="DateInput_PreviewMouseWheel" KeyDown="DateInput_KeyDown" />
                        <TextBlock Text="{DynamicResource Overview.Day}" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" FontSize="16" />
                        <Button Content="{DynamicResource Overview.GoTo}" Height="40" MinWidth="64" Margin="12,0,0,0" Click="GoToDateButton_Click" />
                        <Button Content="{DynamicResource Overview.Today}" Height="40" MinWidth="64" Margin="6,0,0,0" Click="GoToTodayButton_Click" />
                    </StackPanel>
                    <TextBlock x:Name="SelectedDateStatusText" Text="{DynamicResource Overview.Loading}" Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,16">
            <Border Style="{StaticResource OverviewCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.TotalUsage}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="TotalUsageText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource OverviewCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.DailyAvg}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="AverageUsageText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource OverviewCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.TodayUsage}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="TodayUsageText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" Foreground="{DynamicResource AccentRedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource OverviewCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.WeekUsage}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="WeekUsageText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource OverviewCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.SessionCount}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="SessionCountText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource OverviewCardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Overview.ProcessCount}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="ProcessCountText" Text="--" Margin="0,10,0,0" FontSize="27" FontWeight="Black" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource OverviewCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Overview.DataStatus}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Black" />
                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,16,0,0">
                        <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="16" Padding="14" Margin="0,0,10,0"><StackPanel><TextBlock Text="{DynamicResource Overview.EarliestRecord}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Bold" /><TextBlock x:Name="EarliestDateText" Text="--" Margin="0,8,0,0" FontSize="18" FontWeight="Black" /></StackPanel></Border>
                        <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="16" Padding="14" Margin="0,0,10,0"><StackPanel><TextBlock Text="{DynamicResource Overview.CurrentScope}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Bold" /><TextBlock x:Name="CurrentScopeText" Text="--" Margin="0,8,0,0" FontSize="18" FontWeight="Black" /></StackPanel></Border>
                        <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="16" Padding="14"><StackPanel><TextBlock Text="{DynamicResource Overview.ActiveState}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Bold" /><TextBlock x:Name="IdleStateText" Text="--" Margin="0,8,0,0" FontSize="18" FontWeight="Black" /></StackPanel></Border>
                    </UniformGrid>
                    <Border Grid.Row="2" Margin="0,16,0,0" Padding="18" CornerRadius="18" Background="{DynamicResource InputBackgroundBrush}">
                        <TextBlock x:Name="OverviewStateText" Text="{DynamicResource Overview.WaitingInit}" FontSize="22" FontWeight="Black" TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
