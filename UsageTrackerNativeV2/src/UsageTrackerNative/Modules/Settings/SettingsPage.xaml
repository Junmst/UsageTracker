<UserControl x:Class="UsageTrackerNative.Modules.Settings.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrushAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="TransferMenuButtonBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TransferMenuItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="SettingsRoot" PreviewMouseDown="SettingsRoot_PreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="设置" FontSize="34" FontWeight="Black" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="数据工具" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="ExportMenuHost" Height="38" Panel.ZIndex="40" MouseEnter="TransferMenuSafeArea_MouseEnter" MouseLeave="TransferMenuSafeArea_MouseLeave">
                            <Border Style="{StaticResource TransferMenuButtonBorderStyle}" MouseLeftButtonDown="ExportMenuButton_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="导出" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Border Grid.Column="1" Background="Transparent">
                                        <TextBlock Text="▾" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Black" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="ExportMenuPopup" PlacementTarget="{Binding ElementName=ExportMenuHost}" Placement="Bottom" AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="8">
                                <Border x:Name="ExportMenuFlyout" Width="{Binding ActualWidth, ElementName=ExportMenuHost}" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0,6" Opacity="0" MouseEnter="TransferMenuSafeArea_MouseEnter" MouseLeave="TransferMenuSafeArea_MouseLeave">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ExportMenuFlyoutTransform" Y="-8" />
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ExportUsage" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="导出数据" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ExportSettings" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="导出配置" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ExportFull" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="完整备份" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Grid Grid.Column="2" x:Name="ImportMenuHost" Height="38" Panel.ZIndex="40" MouseEnter="TransferMenuSafeArea_MouseEnter" MouseLeave="TransferMenuSafeArea_MouseLeave">
                            <Border Style="{StaticResource TransferMenuButtonBorderStyle}" MouseLeftButtonDown="ImportMenuButton_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="导入" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Border Grid.Column="1" Background="Transparent">
                                        <TextBlock Text="▾" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Black" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="ImportMenuPopup" PlacementTarget="{Binding ElementName=ImportMenuHost}" Placement="Bottom" AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="8">
                                <Border x:Name="ImportMenuFlyout" Width="{Binding ActualWidth, ElementName=ImportMenuHost}" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0,6" Opacity="0" MouseEnter="TransferMenuSafeArea_MouseEnter" MouseLeave="TransferMenuSafeArea_MouseLeave">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ImportMenuFlyoutTransform" Y="-8" />
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ImportUsage" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="导入数据" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ImportSettings" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="导入配置" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource TransferMenuItemStyle}" Tag="ImportFull" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                            <TextBlock Text="导入完整备份" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                    <TextBlock x:Name="StatusText" Text="就绪" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="2,4,2,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="运行设置" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Border Style="{StaticResource SettingRowStyle}" MouseLeftButtonDown="StartupRow_MouseLeftButtonDown" Cursor="Hand">
                        <Grid>
                            <TextBlock Text="开机自动启动" VerticalAlignment="Center" FontWeight="Bold" />
                            <TextBlock x:Name="StartupStateText" Text="读取中" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Black" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="空闲判定" VerticalAlignment="Center" FontWeight="Bold" />
                            <TextBox x:Name="IdleTimeoutInput" Grid.Column="1" Height="34" Width="70" HorizontalAlignment="Right" VerticalContentAlignment="Center" PreviewKeyDown="IdleTimeoutInput_PreviewKeyDown" />
                            <Button Grid.Column="2" Content="保存" Height="34" MinWidth="58" Margin="8,0,0,0" Click="SaveIdleTimeoutButton_Click" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel>
                    <TextBlock Text="快捷键" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="手动空闲" VerticalAlignment="Center" FontWeight="Bold" />
                            <TextBox x:Name="ManualIdleShortcutInput" Grid.Column="1" Height="34" Margin="14,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" PreviewKeyDown="ManualIdleShortcutInput_PreviewKeyDown" />
                            <Button Grid.Column="2" Content="保存" Height="34" MinWidth="58" Margin="8,0,0,0" Click="SaveShortcutButton_Click" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource SettingsCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="主题色" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Border x:Name="AccentPlane" Grid.Row="1" CornerRadius="22" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Cross"
                            MouseLeftButtonDown="AccentPlane_MouseLeftButtonDown" MouseMove="AccentPlane_MouseMove" MouseLeftButtonUp="AccentPlane_MouseLeftButtonUp">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFF2A00" Offset="0" />
                                <GradientStop Color="#FFFFFF00" Offset="0.18" />
                                <GradientStop Color="#FF00E676" Offset="0.36" />
                                <GradientStop Color="#FF00C8FF" Offset="0.52" />
                                <GradientStop Color="#FF2A36FF" Offset="0.68" />
                                <GradientStop Color="#FFC000FF" Offset="0.84" />
                                <GradientStop Color="#FFFF2F8C" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid ClipToBounds="True">
                            <Rectangle RadiusX="22" RadiusY="22">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Ellipse x:Name="AccentPlaneThumb" Width="26" Height="26" Stroke="White" StrokeThickness="4" Fill="Transparent"
                                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0" IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="0,16,0,0" VerticalAlignment="Bottom">
                        <Border x:Name="AccentShadeBar" Height="18" CornerRadius="9" Cursor="Hand"
                                MouseWheel="AccentShadeBar_MouseWheel"
                                MouseLeftButtonDown="AccentShadeBar_MouseLeftButtonDown" MouseMove="AccentShadeBar_MouseMove" MouseLeftButtonUp="AccentShadeBar_MouseLeftButtonUp">
                            <Border.Background>
                                <LinearGradientBrush x:Name="AccentShadeBrush" StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF000000" Offset="0" />
                                    <GradientStop Color="#FF8B0008" Offset="0.35" />
                                    <GradientStop Color="#FFFF0012" Offset="0.7" />
                                    <GradientStop Color="#FFFFFFFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ClipToBounds="False">
                                <Ellipse x:Name="AccentShadeThumb" Width="22" Height="22" Stroke="White" StrokeThickness="4" Fill="Transparent"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <Border x:Name="AccentSaturationBar" Height="18" CornerRadius="9" Margin="0,14,0,0" Cursor="Hand"
                                MouseWheel="AccentSaturationBar_MouseWheel"
                                MouseLeftButtonDown="AccentSaturationBar_MouseLeftButtonDown" MouseMove="AccentSaturationBar_MouseMove" MouseLeftButtonUp="AccentSaturationBar_MouseLeftButtonUp">
                            <Border.Background>
                                <LinearGradientBrush x:Name="AccentSaturationBrush" StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF808080" Offset="0" />
                                    <GradientStop Color="#FFFF0012" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ClipToBounds="False">
                                <Ellipse x:Name="AccentSaturationThumb" Width="22" Height="22" Stroke="White" StrokeThickness="4" Fill="Transparent"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="颜色预览" FontSize="18" FontWeight="Black" Margin="0,0,0,14" />
                    <Border Grid.Row="1" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="PreviewColorSwatch" Background="{DynamicResource AccentRedBrush}"><TextBlock Text="取色预览" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" Foreground="White" /></Border>
                            <Border Grid.Column="1" Background="#252525"><TextBlock Text="当前主题色" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource AccentRedBrush}" /></Border>
                            <Border x:Name="CurrentColorSwatch" Grid.Row="1" Background="{DynamicResource AccentRedBrush}"><TextBlock Text="已应用" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" Foreground="White" /></Border>
                            <Border Grid.Row="1" Grid.Column="1" Background="#F4F4F5"><TextBlock Text="当前主题色" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" Foreground="{DynamicResource AccentRedBrush}" /></Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button x:Name="AccentSlotButton1" Tag="0" Content="" MinWidth="76" Height="42" Click="AccentSlot_Click" ToolTip="左键应用保存颜色，右键保存当前主题色" />
                        <Button x:Name="AccentSlotButton2" Tag="1" Content="" MinWidth="76" Height="42" Margin="10,0,0,0" Click="AccentSlot_Click" ToolTip="左键应用保存颜色，右键保存当前主题色" />
                        <Button x:Name="AccentSlotButton3" Tag="2" Content="" MinWidth="76" Height="42" Margin="10,0,0,0" Click="AccentSlot_Click" ToolTip="左键应用保存颜色，右键保存当前主题色" />
                        <Button Content="完成" MinWidth="90" Height="42" Margin="18,0,0,0" Click="DoneButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
