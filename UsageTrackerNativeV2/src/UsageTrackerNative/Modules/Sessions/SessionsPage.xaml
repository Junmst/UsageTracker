<UserControl x:Class="UsageTrackerNative.Modules.Sessions.SessionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             PreviewMouseDown="SessionsPage_PreviewMouseDown">
    <UserControl.Resources>
        <Style x:Key="SessionGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SessionGridHeaderLeftStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource SessionGridHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="SessionGridHeaderCenterStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource SessionGridHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SessionGridHeaderRightStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource SessionGridHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style x:Key="SessionGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="Stretch"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SessionGridLeftCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource SessionGridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="SessionGridCenterCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource SessionGridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SessionGridRightCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource SessionGridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style x:Key="SessionGridLeftTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SessionGridRightMonoTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SessionGridDurationTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SessionGridRightMonoTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SessionSubjectTagTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SessionSubjectTagTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SessionGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Grid x:Name="RowRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Border x:Name="BottomDivider"
                                    VerticalAlignment="Bottom"
                                    Height="1"
                                    Background="{DynamicResource SessionRowDividerBrush}" />
                            <Border x:Name="StateBackground"
                                    Background="Transparent"
                                    Opacity="1" />
                            <Rectangle x:Name="SelectedIndicator"
                                       Width="2"
                                       HorizontalAlignment="Left"
                                       Fill="{DynamicResource SessionRowSelectedIndicatorBrush}"
                                       Visibility="Collapsed" />
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <SelectiveScrollingGrid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </SelectiveScrollingGrid.RowDefinitions>
                                <DataGridCellsPresenter Grid.Column="1"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                <DataGridDetailsPresenter Grid.Column="1"
                                                          Grid.Row="1"
                                                          SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                          Visibility="{TemplateBinding DetailsVisibility}" />
                                <DataGridRowHeader Grid.RowSpan="2"
                                                   SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                                                   Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                            </SelectiveScrollingGrid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StateBackground" Property="Background" Value="{DynamicResource SessionRowHoverBrush}" />
                                <Setter TargetName="BottomDivider" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="StateBackground" Property="Background" Value="{DynamicResource SessionRowSelectedBackgroundBrush}" />
                                <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible" />
                                <Setter TargetName="BottomDivider" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="StateBackground" Property="Background" Value="{DynamicResource SessionRowSelectedBackgroundBrush}" />
                                <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible" />
                                <Setter TargetName="BottomDivider" Property="Visibility" Value="Collapsed" />
                            </MultiTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter TargetName="StateBackground" Property="Background" Value="{DynamicResource SessionRowSelectedBackgroundBrush}" />
                                <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible" />
                                <Setter TargetName="BottomDivider" Property="Visibility" Value="Collapsed" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubjectScopeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Opacity="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchModeButtonBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                    <Setter Property="Opacity" Value="0.96" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchModeItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Sessions.Title}" FontSize="34" FontWeight="Black" />
            </StackPanel>
            <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="16,10" VerticalAlignment="Top">
                <TextBlock x:Name="ActiveSessionText" Text="{DynamicResource Sessions.ActiveSession}" FontWeight="Black" />
            </Border>
            <Border x:Name="PreviewModeBanner" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputFocusBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="14,10" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PreviewModeText" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <Button Grid.Column="1" Content="{DynamicResource Sessions.ExitPreview}" Height="30" MinWidth="92" Margin="14,0,0,0" Click="ExitPreviewModeButton_Click" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="20" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox" Height="38" VerticalContentAlignment="Center" Text="{DynamicResource Sessions.SearchPlaceholder}" Foreground="{DynamicResource SecondaryTextBrush}" KeyDown="SearchTextBox_KeyDown" GotFocus="SearchTextBox_GotFocus" />
                <Grid Grid.Column="1" x:Name="SearchModeHost" Width="138" Height="38" Margin="10,0,0,0" Panel.ZIndex="40" MouseRightButtonUp="SearchModeHost_MouseRightButtonUp">
                    <Border x:Name="SearchModeButtonBorder" Style="{StaticResource SearchModeButtonBorderStyle}" FocusVisualStyle="{x:Null}" Focusable="False" MouseLeftButtonDown="SearchModeButton_MouseLeftButtonDown" PreviewMouseLeftButtonUp="SearchModeButton_PreviewMouseLeftButtonUp" MouseLeave="SearchModeButton_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SearchButtonText" Text="{DynamicResource Sessions.SearchAll}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Cursor="Hand" MouseLeftButtonUp="SearchButtonText_MouseLeftButtonUp" />
                            <Border Grid.Column="1" Background="Transparent" Cursor="Hand" MouseLeftButtonUp="SearchModeDropDown_MouseLeftButtonUp">
                                <TextBlock Text="▾" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Black" Foreground="{DynamicResource SecondaryTextBrush}" />
                            </Border>
                        </Grid>
                    </Border>
                    <Popup x:Name="SearchModePopup" PlacementTarget="{Binding ElementName=SearchModeHost}" Placement="Bottom" AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="8">
                        <Border x:Name="SearchModeFlyout" Width="138" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0,6" Opacity="0" MouseEnter="SearchModeFlyout_MouseEnter" MouseLeave="SearchModeFlyout_MouseLeave">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="SearchModeFlyoutTransform" Y="-8" />
                            </Border.RenderTransform>
                            <StackPanel>
                                <Border Style="{StaticResource SearchModeItemStyle}" Tag="All" MouseLeftButtonUp="SearchModeItem_MouseLeftButtonUp">
                                    <TextBlock x:Name="AllSearchModeText" Text="{DynamicResource Sessions.SearchAll}" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource SearchModeItemStyle}" Tag="Subject" MouseLeftButtonUp="SearchModeItem_MouseLeftButtonUp">
                                    <TextBlock x:Name="SubjectSearchModeText" Text="{DynamicResource Sessions.SearchSubject}" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource SearchModeItemStyle}" Tag="Title" MouseLeftButtonUp="SearchModeItem_MouseLeftButtonUp">
                                    <TextBlock x:Name="TitleSearchModeText" Text="{DynamicResource Sessions.SearchTitle}" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource SearchModeItemStyle}" Tag="Process" MouseLeftButtonUp="SearchModeItem_MouseLeftButtonUp">
                                    <TextBlock x:Name="ProcessSearchModeText" Text="{DynamicResource Sessions.SearchProcess}" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <Button Grid.Column="2" x:Name="SubjectScopeButton" Style="{StaticResource SubjectScopeButtonStyle}" MinWidth="118" Height="40" Padding="14,0" Margin="10,0,0,0" Click="SubjectScopeButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TodayScopeText" Text="{DynamicResource Sessions.ScopeToday}" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="/" FontSize="15" FontWeight="SemiBold" Margin="2,0" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="HistoryScopeText" Text="{DynamicResource Sessions.ScopeHistory}" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" x:Name="UndoButton" Content="{DynamicResource Sessions.Undo}" MinWidth="74" Height="38" Margin="10,0,0,0" Click="UndoButton_Click" />
                <Border Grid.Column="4" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="12" Padding="14,0" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="DeleteSelectedButton" Content="{DynamicResource Sessions.Delete}" Height="30" MinWidth="58" Margin="0,4,10,4" Click="DeleteSelectedButton_Click" />
                        <TextBlock x:Name="SelectedCountText" Text="{DynamicResource Sessions.SelectedCount}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SearchSummaryPanel" Grid.Row="2" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="14,8" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="SearchSummaryText" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="22" Padding="0">
            <Grid>
                        <DataGrid x:Name="SessionsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          LostKeyboardFocus="SessionsGrid_LostKeyboardFocus"
                          PreviewKeyDown="SessionsGrid_PreviewKeyDown"
                          PreviewMouseLeftButtonDown="SessionsGrid_PreviewMouseLeftButtonDown"
                          PreviewMouseRightButtonDown="SessionsGrid_PreviewMouseRightButtonDown"
                          PreviewMouseMove="SessionsGrid_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="SessionsGrid_PreviewMouseLeftButtonUp"
                          PreviewMouseWheel="SessionsGrid_PreviewMouseWheel"
                          Loaded="SessionsGrid_Loaded"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="36"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="True"
                          ColumnHeaderStyle="{StaticResource SessionGridHeaderStyle}"
                          CellStyle="{StaticResource SessionGridCellStyle}"
                          RowStyle="{StaticResource SessionGridRowStyle}"
                          RowDetailsVisibilityMode="VisibleWhenSelected">
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Margin="10,0,10,8" Padding="12,8" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasParallelActivities}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Sessions.ParallelActivity}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <ItemsControl ItemsSource="{Binding ParallelActivities}" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1" Text="{Binding DurationText}" Margin="12,0,0,0" FontFamily="Consolas" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.Process}" Width="180" HeaderStyle="{StaticResource SessionGridHeaderLeftStyle}" CellStyle="{StaticResource SessionGridLeftCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProcessName}" Style="{StaticResource SessionGridLeftTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.WindowTitle}" Width="*" HeaderStyle="{StaticResource SessionGridHeaderLeftStyle}" CellStyle="{StaticResource SessionGridLeftCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource SessionGridLeftTextStyle}" />
                                            <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="8" Background="{DynamicResource MenuHoverBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" ToolTip="并行活动不计入主使用时长">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasParallelActivities}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{DynamicResource Sessions.ParallelLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentRedBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.Subject}" Width="160" HeaderStyle="{StaticResource SessionGridHeaderCenterStyle}" CellStyle="{StaticResource SessionGridCenterCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SessionSubjectTagBackgroundBrush}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SubjectText}" Style="{StaticResource SessionSubjectTagTextStyle}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.StartTime}" Width="140" HeaderStyle="{StaticResource SessionGridHeaderRightStyle}" CellStyle="{StaticResource SessionGridRightCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StartText}" Style="{StaticResource SessionGridRightMonoTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.EndTime}" Width="140" HeaderStyle="{StaticResource SessionGridHeaderRightStyle}" CellStyle="{StaticResource SessionGridRightCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EndText}" Style="{StaticResource SessionGridRightMonoTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Sessions.Column.Duration}" Width="90" HeaderStyle="{StaticResource SessionGridHeaderRightStyle}" CellStyle="{StaticResource SessionGridRightCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DurationText}" Style="{StaticResource SessionGridDurationTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="EmptyHintText"
                           Text="{DynamicResource Sessions.NoSession}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontWeight="Black" />
                <Canvas x:Name="SelectionOverlay"
                        Background="Transparent"
                        IsHitTestVisible="False"
                        Visibility="Collapsed"
                        Panel.ZIndex="8">
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</UserControl>
