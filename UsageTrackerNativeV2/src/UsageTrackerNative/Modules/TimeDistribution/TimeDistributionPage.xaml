<UserControl x:Class="UsageTrackerNative.Modules.TimeDistribution.TimeDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:td="clr-namespace:UsageTrackerNative.TimeDistribution">
    <UserControl.Resources>

        <Style x:Key="DistributionFilterButtonStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                    <Setter Property="Opacity" Value="0.96" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubjectFilterItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid PreviewMouseDown="TimeDistributionPage_PreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="时长分布" FontSize="34" FontWeight="Black" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Border x:Name="SevenDaysButton" Style="{StaticResource DistributionFilterButtonStyle}" Height="40" MinWidth="96" Cursor="Hand" MouseLeftButtonUp="SevenDaysButton_Click" MouseEnter="DistributionFilterButton_MouseEnter" MouseLeftButtonDown="DistributionFilterButton_MouseLeftButtonDown" PreviewMouseLeftButtonUp="DistributionFilterButton_MouseLeftButtonUp" MouseLeave="DistributionFilterButton_MouseLeave">
                    <TextBlock Text="最近七天" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </Border>
                <Border x:Name="MonthButton" Style="{StaticResource DistributionFilterButtonStyle}" Height="40" MinWidth="86" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonUp="MonthButton_Click" MouseEnter="DistributionFilterButton_MouseEnter" MouseLeftButtonDown="DistributionFilterButton_MouseLeftButtonDown" PreviewMouseLeftButtonUp="DistributionFilterButton_MouseLeftButtonUp" MouseLeave="DistributionFilterButton_MouseLeave">
                    <TextBlock Text="月视图" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                </Border>
                <Grid x:Name="SubjectFilterHost" Width="142" Height="40" Margin="10,0,0,0" Panel.ZIndex="40" MouseRightButtonUp="SubjectFilterHost_MouseRightButtonUp" MouseEnter="SubjectFilterMenuArea_MouseEnter" MouseLeave="SubjectFilterMenuArea_MouseLeave">
                    <Border x:Name="SubjectFilterButtonBorder" Style="{StaticResource DistributionFilterButtonStyle}" MouseEnter="DistributionFilterButton_MouseEnter" MouseLeftButtonDown="DistributionFilterButton_MouseLeftButtonDown" PreviewMouseLeftButtonUp="DistributionFilterButton_MouseLeftButtonUp" MouseLeave="DistributionFilterButton_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SubjectFilterButtonText" Text="全部分类" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource PrimaryTextBrush}" Cursor="Hand" MouseLeftButtonUp="SubjectFilterButtonText_MouseLeftButtonUp" />
                            <Border Grid.Column="1" Background="Transparent" Cursor="Hand" MouseLeftButtonUp="SubjectFilterDropDown_MouseLeftButtonUp">
                                <TextBlock Text="▾" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Black" Foreground="{DynamicResource SecondaryTextBrush}" />
                            </Border>
                        </Grid>
                    </Border>
                    <Popup x:Name="SubjectFilterPopup" PlacementTarget="{Binding ElementName=SubjectFilterHost}" Placement="Bottom" AllowsTransparency="True" StaysOpen="True" HorizontalOffset="0" VerticalOffset="8">
                        <Border x:Name="SubjectFilterFlyout" Width="168" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0,6" Opacity="0" MouseEnter="SubjectFilterMenuArea_MouseEnter" MouseLeave="SubjectFilterMenuArea_MouseLeave">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="SubjectFilterFlyoutTransform" Y="-8" />
                            </Border.RenderTransform>
                            <StackPanel x:Name="SubjectFilterMenuPanel" />
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="22" Padding="14">
            <td:TimeDistributionControl x:Name="DistributionControl" />
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource PanelBrushAlt}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="20" Padding="14" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="SelectedSessionTitleText" Text="未选择会话" FontSize="18" FontWeight="Black" />
                    <TextBlock x:Name="SelectedSessionMetaText" Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Content="查看完整明细" Height="40" MinWidth="116" Click="ViewDetailsButton_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
