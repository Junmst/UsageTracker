                            <TextBox x:Name="ManualIdleShortcutTextBox" Grid.Column="4" Height="34" Margin="12,0,0,0" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" IsReadOnly="True" ToolTip="点击后同时按下 Ctrl/Alt/Shift/Win 和另一个键自动设置" PreviewKeyDown="ManualIdleShortcutTextBox_KeyDown" />
                            <Button Grid.Column="5" Content="应用快捷键" Click="ApplyManualIdleShortcut_Click" MinWidth="104" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <TextBlock x:Name="IdleTimeoutStatusText" Grid.Column="6" Margin="16,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="单位：分钟" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Button x:Name="ExportMenuButton" Click="ExportMenuButton_Click" MinWidth="110" Height="34" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="导出" />
                                        <TextBlock Text=" ▾" Margin="4,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Popup x:Name="ExportMenuPopup" PlacementTarget="{Binding ElementName=ExportMenuButton}" Placement="Bottom" AllowsTransparency="True" StaysOpen="True">
                                    <Border x:Name="ExportMenuFlyout" Width="132" Margin="0,6,0,0" Padding="0,6" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" CornerRadius="10" Opacity="0" MouseEnter="TransferMenuFlyout_MouseEnter" MouseLeave="TransferMenuFlyout_MouseLeave">
