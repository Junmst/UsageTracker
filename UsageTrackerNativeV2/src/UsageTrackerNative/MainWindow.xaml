                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource PrimaryTextBrush}"
                                            Click="KeywordRuleListButton_Click" />
