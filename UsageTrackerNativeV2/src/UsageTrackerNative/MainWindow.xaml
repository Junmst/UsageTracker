                                            <TranslateTransform x:Name="ExportMenuFlyoutTransform" Y="-8" />
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <Border Tag="ExportUsage" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
