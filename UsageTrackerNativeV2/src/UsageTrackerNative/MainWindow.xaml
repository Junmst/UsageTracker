                            <Button Grid.Column="2" Content="应用" Click="ApplyIdleTimeout_Click" MinWidth="76" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
