                                                                                <Border Grid.Column="2" Background="{DynamicResource CategoryBadgeBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding TotalDurationText}" FontSize="12" Foreground="{DynamicResource CategoryBadgeTextBrush}" VerticalAlignment="Center" />
                                                                                </Border>
                                                                                <Border Grid.Column="3" Background="{DynamicResource CategoryBadgeBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding ProcessCountText}" FontSize="12" Foreground="{DynamicResource CategoryBadgeTextBrush}" VerticalAlignment="Center" />
                                                                                </Border>
                                                                                <Button Grid.Column="4" Tag="{Binding}" Click="ToggleSubjectExpand_Click" Content="{Binding ExpandGlyph}" Style="{StaticResource SubjectExpandButtonStyle}" Margin="4,0,0,0" />
                                                                            </Grid>
                                                                            <ItemsControl ItemsSource="{Binding Children}" Visibility="{Binding ChildrenVisibility}" Margin="12,8,0,0">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Border Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,6">
                                                                                            <Grid>
                                                                                                <Grid.ColumnDefinitions>
                                                                                                    <ColumnDefinition Width="Auto" />
                                                                                                    <ColumnDefinition Width="*" />
                                                                                                    <ColumnDefinition Width="Auto" />
                                                                                                </Grid.ColumnDefinitions>
                                                                                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                                <TextBlock Grid.Column="1" Text="{Binding SubjectName}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                                                                                                <Border Grid.Column="2" Background="{DynamicResource CategoryBadgeBrush}" CornerRadius="999" Padding="10,4" VerticalAlignment="Center">
                                                                                                    <TextBlock Text="{Binding TotalDurationText}" FontSize="12" Foreground="{DynamicResource CategoryBadgeTextBrush}" VerticalAlignment="Center" />
