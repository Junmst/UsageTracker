                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewGrandChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewGrandChildSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="{DynamicResource Subjects.AddChild}" Click="AddGrandChildSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="GrandChildSubjectList" Tag="{DynamicResource Subjects.SelectChild}" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="GrandChildSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteGrandChildSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="{DynamicResource Subjects.ChildDeleteCount}" /><Button Grid.Column="1" Content="{DynamicResource Subjects.ClearChildDelete}" Click="ClearDeleteGrandChildSubjects_Click" MinWidth="132" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteGrandChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteGrandChildSubjectTextBox_KeyDown" TextChanged="DeleteGrandChildSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="{DynamicResource Subjects.BatchDeleteChild}" Click="RemoveGrandChildSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
