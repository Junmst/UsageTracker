                        <TextBlock x:Name="SelectedDateSummaryText" Text="{DynamicResource History.TodayRealtime}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DatePickerTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DatePickerTextBox_KeyDown" />
                            <Button Grid.Column="1" Content="{DynamicResource History.ViewDate}" Click="LoadSelectedDate_Click" MinWidth="96" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <Button Grid.Column="2" Content="{DynamicResource History.BackToToday}" Click="ViewToday_Click" MinWidth="96" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <TextBlock x:Name="DateRangeHintText" Grid.Column="3" Margin="16,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{DynamicResource History.DateFormat}" TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SubjectManagementEntryButton"
                                Content="{DynamicResource Subjects.Title}"
                                Click="SubjectManagementEntryButton_Click"
                                Height="44"
                                Margin="0,0,8,0"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                FontSize="15"
                                FontWeight="SemiBold" />
                        <Button x:Name="HistoryToolsEntryButton"
                                Grid.Column="1"
                                Content="{DynamicResource Common.HistoryDate}"
                                Click="HistoryToolsEntryButton_Click"
                                Height="44"
                                Margin="8,0,0,0"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                FontSize="15"
                                FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>




