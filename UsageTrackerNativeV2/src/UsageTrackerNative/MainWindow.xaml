                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1.15*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="大类" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="新增大类" Click="AddSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="ParentSubjectList" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="ParentSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="待删除大类：0 项" /><Button Grid.Column="1" Content="清空删除栏" Click="ClearDeleteSubjects_Click" MinWidth="110" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteSubjectTextBox_KeyDown" TextChanged="DeleteSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="批量删除大类" Click="RemoveSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="父类" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ComboBox x:Name="ParentSubjectComboBox" Tag="选择大类" Height="38" Padding="10,6" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="ParentSubjectComboBox_SelectionChanged" />
                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewChildSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="新增父类" Click="AddChildSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="ChildSubjectList" Tag="选择父类" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="ChildSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteChildSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="待删除父类：0 项" /><Button Grid.Column="1" Content="清空父类删除栏" Click="ClearDeleteChildSubjects_Click" MinWidth="132" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteChildSubjectTextBox_KeyDown" TextChanged="DeleteChildSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="批量删除父类" Click="RemoveChildSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                <TextBlock Text="子类" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ComboBox x:Name="GrandChildParentComboBox" Tag="选择父类" Height="38" Padding="10,6" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="GrandChildParentComboBox_SelectionChanged" />
                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewGrandChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewGrandChildSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="新增子类" Click="AddGrandChildSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="GrandChildSubjectList" Tag="选择子类" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="GrandChildSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteGrandChildSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="待删除子类：0 项" /><Button Grid.Column="1" Content="清空子类删除栏" Click="ClearDeleteGrandChildSubjects_Click" MinWidth="132" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteGrandChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteGrandChildSubjectTextBox_KeyDown" TextChanged="DeleteGrandChildSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="批量删除子类" Click="RemoveGrandChildSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="关键词规则" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Button x:Name="KeywordRuleSubjectButton" Content="选择分类 ▾" Height="38" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" Click="KeywordRuleSubjectButton_Click" />
                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="KeywordRuleTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="KeywordRuleTextBox_KeyDown" /><Button Grid.Column="1" Content="新增规则" Click="AddKeywordRule_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="KeywordRuleListButton"
                                            Content="选择规则 ▾"
                                            Height="38"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource PrimaryTextBrush}"
                                            Click="KeywordRuleListButton_Click" />
                                    <Border x:Name="KeywordRuleListPanel"
                                            Grid.Row="1"
                                            Margin="0,8,0,0"
                                            MinWidth="0"
                                            MaxHeight="180"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Visibility="Collapsed">
                                        <ListBox x:Name="KeywordRuleList"
                                                 SelectionMode="Multiple"
                                                 Height="180"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.CanContentScroll="True"
                                                 PreviewMouseWheel="KeywordRuleList_PreviewMouseWheel"
                                                 SelectionChanged="KeywordRuleList_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                    <Setter Property="Padding" Value="4,3" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="ItemBorder"
                                                                        Margin="4,2"
                                                                        Padding="12,7"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6"
                                                                        SnapsToDevicePixels="True">
                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                      VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}" />
                                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </Trigger>
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsSelected" Value="True" />
                                                                            <Condition Property="Selector.IsSelectionActive" Value="False" />
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedInactiveBrush}" />
                                                                    </MultiTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteKeywordRuleSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="待删除规则：0 项" /><Button Grid.Column="1" Content="清空规则删除栏" Click="ClearDeleteKeywordRules_Click" MinWidth="132" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteKeywordRuleTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteKeywordRuleTextBox_KeyDown" TextChanged="DeleteKeywordRuleTextBox_TextChanged" /><Button Grid.Column="1" Content="删除规则" Click="RemoveKeywordRule_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="HistoryToolsPanel" Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,14,14,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="历史日期查看" Style="{StaticResource SectionTitleStyle}" />
