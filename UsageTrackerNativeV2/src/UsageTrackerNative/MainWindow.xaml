                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource Subjects.Major}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="{DynamicResource Subjects.AddMajor}" Click="AddSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="ParentSubjectList" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="ParentSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="{DynamicResource Subjects.MajorDeleteCount}" /><Button Grid.Column="1" Content="{DynamicResource Subjects.ClearDelete}" Click="ClearDeleteSubjects_Click" MinWidth="110" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteSubjectTextBox_KeyDown" TextChanged="DeleteSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="{DynamicResource Subjects.BatchDeleteMajor}" Click="RemoveSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource Subjects.Parent}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
