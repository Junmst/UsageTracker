                                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="NewChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="NewChildSubjectTextBox_KeyDown" /><Button Grid.Column="1" Content="{DynamicResource Subjects.AddParent}" Click="AddChildSubject_Click" MinWidth="90" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <ComboBox x:Name="ChildSubjectList" Tag="{DynamicResource Subjects.SelectParent}" Height="38" MaxDropDownHeight="150" Margin="0,0,0,12" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" SelectionChanged="ChildSubjectList_SelectionChanged" />
                                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="DeleteChildSelectionSummaryText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="{DynamicResource Subjects.ParentDeleteCount}" /><Button Grid.Column="1" Content="{DynamicResource Subjects.ClearParentDelete}" Click="ClearDeleteChildSubjects_Click" MinWidth="132" Height="30" Padding="14,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="DeleteChildSubjectTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DeleteChildSubjectTextBox_KeyDown" TextChanged="DeleteChildSubjectTextBox_TextChanged" /><Button Grid.Column="1" Content="{DynamicResource Subjects.BatchDeleteParent}" Click="RemoveChildSubject_Click" MinWidth="110" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" /></Grid>
