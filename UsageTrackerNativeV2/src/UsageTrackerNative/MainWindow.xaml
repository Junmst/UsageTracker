                                            </Border>
                                            <Border Tag="ExportSettings" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                                <TextBlock Text="导出配置" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Border>
                                            <Border Tag="ExportFull" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                                <TextBlock Text="完整备份" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Border>
