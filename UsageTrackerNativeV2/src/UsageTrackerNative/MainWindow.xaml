                            <TextBox x:Name="ManualIdleShortcutTextBox" Grid.Column="4" Height="34" Margin="12,0,0,0" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" IsReadOnly="True" ToolTip="{DynamicResource Settings.ShortcutPrompt}" PreviewKeyDown="ManualIdleShortcutTextBox_KeyDown" />
                            <Button Grid.Column="5" Content="{DynamicResource Settings.ApplyShortcut}" Click="ApplyManualIdleShortcut_Click" MinWidth="104" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <TextBlock x:Name="IdleTimeoutStatusText" Grid.Column="6" Margin="16,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{DynamicResource Settings.UnitMinutes}" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
