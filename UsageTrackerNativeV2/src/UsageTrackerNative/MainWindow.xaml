<Window x:Class="UsageTrackerNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:td="clr-namespace:UsageTrackerNative.TimeDistribution"
        Title="{DynamicResource App.Title}"
        Width="1380"
        Height="980"
        MinWidth="1080"
        MinHeight="760"
        WindowStartupLocation="Manual"
        Left="120"
        Top="80"
        Topmost="False"
        Loaded="Window_Loaded"
        ContentRendered="Window_ContentRendered"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource MainWindow.ReportTitle}" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock x:Name="LoadingIndicator"
                                   Text="{DynamicResource App.Loading}"
                                   FontSize="14"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock Text="{DynamicResource MainWindow.Subtitle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{DynamicResource MainWindow.Description}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="460"
                           Margin="0,0,16,0" />
                <ComboBox Grid.Column="2"
                          x:Name="ThemeModeComboBox"
                          SelectionChanged="ThemeModeComboBox_SelectionChanged"
                          Width="112"
                          Height="42"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Background="{DynamicResource ButtonBackgroundBrush}"
                          BorderBrush="{DynamicResource ButtonBorderBrush}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          BorderThickness="1"
                          FontSize="13"
                          FontWeight="SemiBold">
                    <ComboBoxItem Content="Light" Tag="Light" />
                    <ComboBoxItem Content="Dark" Tag="Dark" />
                    <ComboBoxItem Content="System" Tag="System" />
                </ComboBox>
                <Button Grid.Column="3"
                        x:Name="ThemeAccentButton"
                        Content="{DynamicResource Settings.Theme}"
                        Click="ThemeAccentButton_Click"
                        MinWidth="78"
                        Height="42"
                        Margin="0,0,8,0"
                        Padding="14,0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource MenuSelectedBrush}"
                        BorderBrush="{DynamicResource InputFocusBorderBrush}"
                        Foreground="{DynamicResource SelectedRowTextBrush}"
                        BorderThickness="1"
                        FontSize="13"
                        FontWeight="SemiBold" />
                <Button Grid.Column="4"
                        x:Name="CompactModeButton"
                        Content="◱"
                        Click="ToggleCompactMode_Click"
                        Width="42"
                        Height="42"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        BorderThickness="1"
                        FontSize="16"
                        FontWeight="SemiBold" />
            </Grid>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False" PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <Grid Margin="16,16,1,16" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0" Margin="0,0,0,2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <Border Style="{StaticResource MetricCardBorderStyle}"><StackPanel><Grid ClipToBounds="True"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{DynamicResource Overview.TotalUsage}" Foreground="{DynamicResource SecondaryTextBrush}" /><Canvas Grid.Column="1" Height="24" ClipToBounds="True"><TextBlock x:Name="TotalTitleText" Foreground="{DynamicResource SecondaryTextBrush}" /></Canvas></Grid><TextBlock x:Name="TotalFocusText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" FontSize="26" Foreground="{DynamicResource MetricValueBrush}" /></StackPanel></Border>
                    <Border x:Name="AverageDailyMetricCard" Style="{StaticResource MetricCardBorderStyle}" MouseRightButtonUp="AverageDailyMetricCard_MouseRightButtonUp"><StackPanel><Grid ClipToBounds="True"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{DynamicResource Overview.DailyAvg}" Foreground="{DynamicResource SecondaryTextBrush}" /><Canvas Grid.Column="1" Height="24" ClipToBounds="True"><TextBlock x:Name="AverageDailyTitleText" Foreground="{DynamicResource SecondaryTextBrush}" /></Canvas></Grid><TextBlock x:Name="AverageDailyFocusText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" Foreground="{DynamicResource MetricValueBrush}" FontSize="26" /></StackPanel></Border>
                    <Border Style="{StaticResource MetricCardBorderStyle}"><StackPanel><TextBlock Text="{DynamicResource Overview.TodayUsage}" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock x:Name="TodayFocusText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" Foreground="{DynamicResource AccentBlueBrush}" FontSize="26" /></StackPanel></Border>
                    <Border Style="{StaticResource MetricCardBorderStyle}"><StackPanel><TextBlock Text="{DynamicResource Overview.WeekUsage}" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock x:Name="WeekFocusText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" Foreground="{DynamicResource MetricValueBrush}" FontSize="26" /></StackPanel></Border>
                    <Border Style="{StaticResource MetricCardBorderStyle}"><StackPanel><TextBlock Text="{DynamicResource Overview.SessionCount}" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock x:Name="SessionCountText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" Foreground="{DynamicResource MetricValueBrush}" /></StackPanel></Border>
                    <Border Style="{StaticResource MetricCardBorderStyle}"><StackPanel><TextBlock Text="{DynamicResource Overview.ProcessCount}" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock x:Name="ProcessCountText" Style="{StaticResource MetricValueStyle}" Margin="0,12,0,0" Foreground="{DynamicResource MetricValueBrush}" /></StackPanel></Border>
                </ItemsControl>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" MinWidth="0" />
                        <ColumnDefinition Width="1.3*" MinWidth="0" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,14,14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="SessionsSection" Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0" Width="280" VerticalAlignment="Top" LastChildFill="False">
                                        <TextBlock Text="{DynamicResource Sessions.Title}" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        <Border Margin="12,0,0,0" Padding="10,4" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" CornerRadius="8" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{DynamicResource MainWindow.ActiveProcess}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock x:Name="CurrentProcessText" MinWidth="80" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DockPanel>
                                    <Grid Grid.Column="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="SessionSearchTextBox"
                                                 Height="34"
                                                 MinWidth="60"
                                                 Margin="0,0,0,0"
                                                 Padding="10,6"
                                                 VerticalAlignment="Top"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalAlignment="Stretch"
                                                 Background="{DynamicResource InputBackgroundBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1"
                                                 KeyDown="SessionSearchTextBox_KeyDown" />
                                        <Button Grid.Column="1"
                                                x:Name="SearchSessionsButton"
                                                Content="{DynamicResource Sessions.SearchAll}"
                                                Click="SearchSessions_Click"
                                                MouseRightButtonUp="SearchSessionsButton_MouseRightButtonUp"
                                                Width="88"
                                                Height="34"
                                                Margin="12,0,0,0"
                                                Padding="18,0"
                                                VerticalAlignment="Top"
                                                Background="{DynamicResource ButtonBackgroundBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                BorderThickness="1"
                                                FontWeight="SemiBold" />
                                        <Button Grid.Column="2"
                                                x:Name="SessionSubjectScopeButton"
                                                Click="SessionSubjectScopeButton_Click"
                                                Width="92"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Padding="12,0"
                                                VerticalAlignment="Top"
                                                Background="{DynamicResource ButtonBackgroundBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock x:Name="SessionScopeTodayText" Text="{DynamicResource Sessions.ScopeToday}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="/" Margin="4,0" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock x:Name="SessionScopeHistoryText" Text="{DynamicResource Sessions.ScopeHistory}" FontSize="12" FontWeight="Normal" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="3"
                                                x:Name="UndoSessionActionButton"
                                                Content="{DynamicResource Sessions.Undo}"
                                                Click="UndoSessionAction_Click"
                                                Width="76"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Padding="14,0"
                                                VerticalAlignment="Top"
                                                Background="{DynamicResource ButtonBackgroundBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                BorderThickness="1"
                                                FontWeight="SemiBold"
                                                IsEnabled="False" />
                                    </Grid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock x:Name="SessionSelectionSummaryText"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{DynamicResource Sessions.SelectedCount}" />
                                </Grid>
                                <Grid>
                                    <ScrollViewer x:Name="SessionsOuterScrollViewer"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False"
                                                  PreviewMouseWheel="SessionsGrid_PreviewMouseWheel"
                                                  Height="360">
                                        <DataGrid x:Name="SessionsGrid"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserReorderColumns="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="None"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              RowBackground="{DynamicResource PanelBrushAlt}"
                                              AlternatingRowBackground="{DynamicResource PanelBrush}"
                                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                              VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              EnableRowVirtualization="True"
                                              EnableColumnVirtualization="True"
                                              ScrollViewer.PanningMode="Both"
                                              SelectionMode="Extended"
                                              SelectionUnit="FullRow"
                                              SelectionChanged="SessionsGrid_SelectionChanged"
                                              PreviewMouseLeftButtonDown="SessionsGrid_PreviewMouseLeftButtonDown"
                                              PreviewMouseRightButtonDown="SessionsGrid_PreviewMouseRightButtonDown"
                                              PreviewMouseMove="SessionsGrid_PreviewMouseMove"
                                              PreviewMouseLeftButtonUp="SessionsGrid_PreviewMouseLeftButtonUp"
                                              Loaded="SessionsGrid_Loaded">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" /><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="BorderThickness" Value="0,0,0,1" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Padding" Value="10,8" /></Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Padding" Value="8,6" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridRow">
                                                    <Border x:Name="RowBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            SnapsToDevicePixels="True">
                                                        <DataGridCellsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedInactiveBrush}" />
                                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                                                            <Setter TargetName="RowBorder" Property="BorderThickness" Value="2" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True" />
                                                                <Condition Property="Selector.IsSelectionActive" Value="False" />
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedInactiveBrush}" />
                                                        </MultiTrigger>
                                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}" />
                                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource MenuSelectedBrush}" />
                                                            <Setter TargetName="RowBorder" Property="BorderThickness" Value="2" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.Process}" Binding="{Binding ProcessName}" Width="115" MinWidth="90" />
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.WindowTitle}" Binding="{Binding WindowTitle}" Width="*" MinWidth="160" />
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.Subject}" Binding="{Binding SubjectText}" Width="100" MinWidth="80" />
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.StartTime}" Binding="{Binding StartText}" Width="118" MinWidth="100" />
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.EndTime}" Binding="{Binding EndText}" Width="118" MinWidth="100" />
                                        <DataGridTextColumn Header="{DynamicResource Sessions.Column.Duration}" Binding="{Binding DurationText}" Width="76" MinWidth="66" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                    </ScrollViewer>
                                    <Canvas x:Name="SessionsSelectionOverlay"
                                            Background="Transparent"
                                            IsHitTestVisible="False"
                                            Panel.ZIndex="8">
                                        <Border x:Name="SessionsSelectionRectangle"
                                                Visibility="Collapsed"
                                                Width="0"
                                                Height="0"
                                                Background="{DynamicResource DataGridRowSelectedBrush}"
                                                BorderBrush="{DynamicResource InputFocusBorderBrush}"
                                                BorderThickness="0"
                                                CornerRadius="2" />
                                    </Canvas>
                                    <Border Width="10"
                                            HorizontalAlignment="Right"
                                            Margin="0,42,0,8"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5" />
                                    <Border x:Name="SessionsCustomScrollThumb"
                                            Width="10"
                                            Height="80"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,42,0,0"
                                            Background="{DynamicResource MenuSelectedBrush}"
                                            CornerRadius="5"
                                            Cursor="Hand"
                                            MouseEnter="SessionsCustomScrollThumb_MouseEnter"
                                            MouseLeave="SessionsCustomScrollThumb_MouseLeave"
                                            MouseLeftButtonDown="SessionsCustomScrollThumb_MouseLeftButtonDown"
                                            MouseMove="SessionsCustomScrollThumb_MouseMove"
                                            MouseLeftButtonUp="SessionsCustomScrollThumb_MouseLeftButtonUp" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="TimeDistributionSection" Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="310" />
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="TimeDistributionTitleText" Text="{DynamicResource TimeDist.Title}" Style="{StaticResource SectionTitleStyle}" FontSize="16" />
                                        <TextBlock Text="{DynamicResource TimeDist.Hint}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <Button x:Name="RecentSevenDaysButton" Grid.Column="1" Content="{DynamicResource TimeDist.Recent7Days}" Click="RecentSevenDaysView_Click" MinWidth="88" Height="28" Margin="12,0,0,0" Padding="12,0" Background="{DynamicResource MenuSelectedBrush}" BorderBrush="{DynamicResource InputFocusBorderBrush}" BorderThickness="1" Foreground="{DynamicResource AccentTextBrush}" />
                                    <Button x:Name="MonthViewButton" Grid.Column="2" Content="{DynamicResource TimeDist.MonthView}" Click="MonthView_Click" MinWidth="76" Height="28" Margin="8,0,0,0" Padding="12,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Button x:Name="TimeDistributionFilterButton" Grid.Column="3" Content="{DynamicResource TimeDist.AllSubjectsFilter}" Click="TimeDistributionFilterButton_Click" MinWidth="108" Height="28" Margin="8,0,0,0" Padding="10,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </Grid>
                                <!-- 分布图：专业级 DrawingVisual 渲染架构（自包含 Header + DateColumn + Chart） -->
                                <td:TimeDistributionControl x:Name="TimeDistributionControl"
                                                            Grid.Row="1"
                                                            Cursor="Hand"
                                                            SessionClicked="TimeDistributionControl_SessionClicked" />
                            </Grid>
                        </Border>

                    </Grid>

                    <Grid Grid.Column="1" Margin="0,0,0,14" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                    <Border x:Name="ProcessStatsSection" Grid.Row="0" Style="{StaticResource CardBorderStyle}" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="389" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{DynamicResource TimeDist.ProcStats}" Style="{StaticResource SectionTitleStyle}" FontSize="16" Margin="0,0,0,10" />
                                <ScrollViewer x:Name="ProcessStatsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False" PreviewMouseWheel="StatsScrollViewer_PreviewMouseWheel">
                                    <ListBox x:Name="SummaryItemsControl"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionMode="Single"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             Width="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding ProcessName}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding TotalDurationText}" Foreground="{DynamicResource AccentBlueBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <ProgressBar Height="8" Margin="0,12,0,0" Minimum="0" Maximum="1" Value="{Binding BarRatio}" Style="{StaticResource SummaryBarStyle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border x:Name="SubjectStatsSection" Grid.Row="2" Style="{StaticResource CardBorderStyle}" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="327" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="{DynamicResource TimeDist.SubjectStats}" Style="{StaticResource SectionTitleStyle}" FontSize="16" />
                                </DockPanel>
                                <ScrollViewer x:Name="SubjectStatsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" CanContentScroll="False" PreviewMouseWheel="StatsScrollViewer_PreviewMouseWheel">
                                    <ListBox x:Name="SubjectItemsControl"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionMode="Single"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
