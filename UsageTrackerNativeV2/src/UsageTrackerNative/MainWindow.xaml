                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ImportMenuFlyoutTransform" Y="-8" />
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <Border Tag="ImportUsage" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                                <TextBlock Text="导入数据" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Border>
                                            <Border Tag="ImportSettings" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                                <TextBlock Text="导入配置" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Border>
                                            <Border Tag="ImportFull" Padding="14,9" Cursor="Hand" MouseLeftButtonUp="TransferMenuItem_MouseLeftButtonUp">
                                                <TextBlock Text="导入完整备份" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <TextBlock Grid.Column="2" Margin="16,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="导入采用增量合并；有冲突时先询问，默认保留本地；分类快照保持原样。" />
                        </Grid>
                        <TextBlock x:Name="SelectedDateSummaryText" Text="当前查看：今天（含实时更新）" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DatePickerTextBox" Height="34" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" VerticalContentAlignment="Center" PreviewKeyDown="DatePickerTextBox_KeyDown" />
                            <Button Grid.Column="1" Content="查看日期" Click="LoadSelectedDate_Click" MinWidth="96" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <Button Grid.Column="2" Content="回到今天" Click="ViewToday_Click" MinWidth="96" Height="34" Margin="12,0,0,0" Padding="16,0" Background="{DynamicResource ButtonBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontWeight="SemiBold" />
                            <TextBlock x:Name="DateRangeHintText" Grid.Column="3" Margin="16,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="日期格式：2026-05-04" TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SubjectManagementEntryButton"
                                Content="分类管理"
                                Click="SubjectManagementEntryButton_Click"
                                Height="44"
                                Margin="0,0,8,0"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                FontSize="15"
                                FontWeight="SemiBold" />
                        <Button x:Name="HistoryToolsEntryButton"
                                Grid.Column="1"
                                Content="历史日期查看"
                                Click="HistoryToolsEntryButton_Click"
                                Height="44"
                                Margin="8,0,0,0"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                FontSize="15"
                                FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>




