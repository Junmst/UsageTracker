<Window x:Class="UsageTrackerNative.Shell.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:UsageTrackerNative.Shell"
        Title="时迹"
        Width="1280"
        Height="820"
        MinWidth="920"
        MinHeight="640"
        Icon="pack://application:,,,/Assets/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="ShellNavButtonStyle" TargetType="RadioButton">
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconHost"
                                        Width="30"
                                        Height="30"
                                        CornerRadius="11"
                                        Background="{DynamicResource ButtonBackgroundBrush}">
                                    <TextBlock Text="{Binding IconText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           Margin="10,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="›"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="Black"
                                           Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuSelectedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                <Setter TargetName="IconHost" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ModuleButtonTemplate" DataType="{x:Type shell:AppModuleDefinition}">
            <RadioButton GroupName="ShellModules"
                         Style="{StaticResource ShellNavButtonStyle}"
                         IsChecked="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                         Click="ModuleButton_Click" />
        </DataTemplate>

        <Style x:Key="ThemeModeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="12,0,12,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource InputHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeModeItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HeaderBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 右侧功能按钮区 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="PreviewModeHeaderBanner"
                            Height="36"
                            Margin="0,0,12,0"
                            Padding="14,0"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            BorderBrush="{DynamicResource InputFocusBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="PreviewModeHeaderText"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="360" />
                            <Button Content="退出"
                                    Height="26"
                                    MinWidth="52"
                                    Margin="12,0,0,0"
                                    Click="ExitPreviewModeHeaderButton_Click" />
                        </StackPanel>
                    </Border>
                    <Button Content="小窗"
                            Height="36"
                            MinWidth="72"
                            Margin="0,0,10,0"
                            Click="CompactModeButton_Click" />
                    <TextBlock x:Name="HeaderDateText" Text="--" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Button x:Name="ThemeModeButton"
                            Width="112"
                            Height="40"
                            Style="{StaticResource ThemeModeButtonStyle}"
                            MouseEnter="ThemeModeMenuArea_MouseEnter"
                            MouseLeave="ThemeModeMenuArea_MouseLeave"
                            Click="ThemeModeButton_Click">
                        <Grid>
                            <TextBlock x:Name="ThemeModeButtonText"
                                       Margin="0,0,22,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="System" />
                            <Path Width="10"
                                  Height="6"
                                  Margin="0,0,2,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource SecondaryTextBrush}"
                                  Data="M 0 0 L 5 5 L 10 0 Z" />
                        </Grid>
                    </Button>
                    <Popup x:Name="ThemeModePopup"
                           PlacementTarget="{Binding ElementName=ThemeModeButton}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="True">
                        <Border x:Name="ThemeModeFlyout"
                                Width="112"
                                Margin="0,6,0,0"
                                Padding="0,6,0,6"
                                BorderThickness="1"
                                CornerRadius="8"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0"
                                MouseEnter="ThemeModeMenuArea_MouseEnter"
                                MouseLeave="ThemeModeMenuArea_MouseLeave">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ThemeModeFlyoutScale" ScaleX="0.99" ScaleY="0.985" />
                                    <TranslateTransform x:Name="ThemeModeFlyoutTransform" Y="-4" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Background>
                                <DynamicResource ResourceKey="InputBackgroundBrush" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <DynamicResource ResourceKey="InputBorderBrush" />
                            </Border.BorderBrush>
                            <StackPanel>
                                <Border Tag="System" Style="{StaticResource ThemeModeItemStyle}" MouseLeftButtonUp="ThemeModePopupItem_MouseLeftButtonUp">
                                    <TextBlock Text="System" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </Border>
                                <Border Tag="Light" Style="{StaticResource ThemeModeItemStyle}" MouseLeftButtonUp="ThemeModePopupItem_MouseLeftButtonUp">
                                    <TextBlock Text="Light" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </Border>
                                <Border Tag="Dark" Style="{StaticResource ThemeModeItemStyle}" MouseLeftButtonUp="ThemeModePopupItem_MouseLeftButtonUp">
                                    <TextBlock Text="Dark" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>

                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="26"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="NavigationGroupsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Group}"
                                               Margin="10,0,0,10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="12"
                                               FontWeight="Black" />
                                    <ItemsControl ItemsSource="{Binding Modules}" ItemTemplate="{StaticResource ModuleButtonTemplate}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="28"
                    Padding="22">
                <ContentControl x:Name="ModuleContent" />
            </Border>
        </Grid>
    </Grid>
</Window>
